---
import HomeLikeHeader from '../components/HomeLikeHeader.astro';
import HomeLikeFooter from '../components/HomeLikeFooter.astro';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>الصفحة غير موجودة | عبدالرحمن طاهر</title>
  <meta name="description" content="عذرًا، الصفحة التي تبحث عنها غير موجودة. يمكنك العودة للصفحة الرئيسية أو تصفح الخدمات والمشاريع." />
  <meta name="robots" content="noindex, follow" />
  <link rel="canonical" href="https://abdotaher.me/404/" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" type="image/png" sizes="32x32" href="/image.png" />
  <link rel="apple-touch-icon" href="/image.png" />
  <script src="/site-i18n.js" defer></script>
  <style>
    .not-found {
      max-width: 780px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }
    .card {
      background: rgba(30, 25, 51, 0.9);
      border: 1px solid rgba(112, 213, 230, 0.2);
      border-radius: 22px;
      padding: 1.5rem;
      box-shadow: 0 20px 52px rgba(0, 0, 0, 0.22);
      text-align: center;
    }
    .code {
      color: #8ff700;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin: 0;
    }
    h1 {
      margin: 0.45rem 0 0;
      font-size: clamp(1.9rem, 4vw, 2.6rem);
      color: #ece6ff;
      line-height: 1.35;
    }
    p {
      color: rgba(231, 222, 255, 0.78);
      margin-top: 0.8rem;
      line-height: 1.8;
    }
    .actions {
      margin-top: 1rem;
      display: flex;
      justify-content: center;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      text-decoration: none;
      border-radius: 999px;
      padding: 0.62rem 1rem;
      border: 1px solid rgba(112, 213, 230, 0.2);
      color: #9bf0ff;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .btn.primary {
      background: linear-gradient(135deg, #9bf0ff, #7be4ff);
      color: #03262e;
      border-color: transparent;
    }
  </style>
</head>
<body>
  <HomeLikeHeader />
  <main class="home-like-main">
    <section class="not-found">
      <article class="card">
        <p class="code">404</p>
        <h1 data-ar>الصفحة غير موجودة</h1>
        <h1 data-en>Page Not Found</h1>
        <p data-ar>الرابط الذي فتحته غير متاح حاليًا. يمكنك العودة للرئيسية أو تصفح الخدمات والمشاريع.</p>
        <p data-en>The page you requested is not available. You can return to home or continue browsing services and projects.</p>
        <div class="actions">
          <a class="btn primary" href="/" data-ar>العودة للرئيسية</a>
          <a class="btn primary" href="/" data-en>Back Home</a>
          <a class="btn" href="/services/" data-ar>الخدمات</a>
          <a class="btn" href="/services/" data-en>Services</a>
          <a class="btn" href="/projects/" data-ar>المشاريع</a>
          <a class="btn" href="/projects/" data-en>Projects</a>
        </div>
      </article>
    </section>
  </main>
  <HomeLikeFooter />
</body>
</html>
