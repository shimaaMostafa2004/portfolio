  <style>
    :root{--bg:#0d0b1a;--card:#1e1933;--soft:rgba(30,25,51,.88);--bd:rgba(112,213,230,.14);--tx:#e7deff;--mut:rgba(231,222,255,.72);--pri:#9bf0ff;--acc:#8ff700}
    *{box-sizing:border-box}
    body{margin:0;background:
      radial-gradient(circle at top right, rgba(155,240,255,.08), transparent 30%),
      radial-gradient(circle at bottom left, rgba(143,247,0,.06), transparent 28%),
      var(--bg);color:var(--tx);font-family:'Cairo',sans-serif;line-height:1.9;padding-top:6.5rem}
    .wrap{max-width:1120px;margin:auto;padding:1.25rem}
    .top{position:fixed;top:.5rem;left:50%;transform:translateX(-50%);z-index:100;width:min(calc(100% - 1rem),1120px);display:flex;justify-content:space-between;align-items:center;padding:.9rem 1rem;background:rgba(13,11,26,.88);backdrop-filter:blur(18px);border:1px solid var(--bd);border-radius:18px;box-shadow:0 16px 40px rgba(0,0,0,.22)}
    .brand{font-family:'Space Grotesk',sans-serif;color:var(--pri);font-weight:700;letter-spacing:.08em}
    .nav-actions{display:flex;gap:.6rem;flex-wrap:wrap}
    .btn{display:inline-block;padding:.65rem 1.1rem;border-radius:999px;border:1px solid var(--bd);color:var(--pri);text-decoration:none}
    .btn-flag-link{display:inline-flex;align-items:center;gap:.45rem}
    .btn-flag{display:inline-flex;align-items:center;justify-content:center;padding:.22rem .48rem;border-radius:999px;font-size:.52rem;font-weight:900;letter-spacing:.12em;color:#ffe9d6;background:linear-gradient(135deg,#ff7a18,#ff3d00);box-shadow:0 0 18px rgba(255,90,0,.28)}
    .btn-tab-active{background:rgba(155,240,255,.12);border-color:rgba(155,240,255,.34);color:var(--tx);box-shadow:inset 0 0 0 1px rgba(155,240,255,.08)}
    .btn-primary{background:var(--pri);color:#001f24;border-color:transparent;font-weight:800}
    .hero,.section,.offer-card,.offer-detail,.cta{background:var(--soft);border:1px solid var(--bd);border-radius:20px;box-shadow:0 18px 48px rgba(0,0,0,.18)}
    .hero,.section,.cta,.offer-detail{padding:1.45rem;margin-top:1rem}
    .hero{position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-40px;left:-30px;width:190px;height:190px;border-radius:50%;background:radial-gradient(circle, rgba(155,240,255,.16), transparent 70%)}
    .eyebrow{display:inline-flex;align-items:center;gap:.55rem;padding:.45rem .8rem;border-radius:999px;border:1px solid rgba(155,240,255,.14);background:rgba(255,255,255,.02);color:var(--pri);font-size:.78rem;font-weight:700}
    h1{margin:.85rem 0;font-size:clamp(1.95rem,4.6vw,3.2rem);line-height:1.3;max-width:15ch}
    h2{margin:.1rem 0 .8rem;font-size:1.45rem}
    h3{margin:.1rem 0 .6rem;font-size:1.1rem}
    p,li{color:var(--mut)}
    strong,a{color:var(--pri)}
    .lead{font-size:1.03rem;max-width:66ch}
    .section-kicker{font-size:.75rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--acc);margin-bottom:.35rem}
    .offers-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;margin-top:1rem}
    .offer-card{padding:1.25rem;position:relative}
    .offer-card.featured{border-color:rgba(155,240,255,.36);box-shadow:0 22px 56px rgba(0,0,0,.22)}
    .offer-badge{display:inline-block;padding:.35rem .7rem;border-radius:999px;background:rgba(143,247,0,.12);border:1px solid rgba(143,247,0,.24);color:var(--acc);font-size:.72rem;font-weight:800;letter-spacing:.08em}
    .offer-sub{font-size:.92rem;margin-bottom:.9rem}
    .offer-card ul{margin:.65rem 0 0;padding-inline-start:1.1rem}
    .offer-card li{margin-bottom:.38rem}
    .price-note{margin-top:1rem;padding-top:.9rem;border-top:1px dashed var(--bd)}
    .offer-link{display:inline-flex;align-items:center;gap:.4rem;margin-top:1rem;font-weight:800}
    .offer-detail-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:1rem;align-items:start}
    .detail-box{border:1px dashed var(--bd);border-radius:16px;padding:1rem;background:rgba(255,255,255,.02)}
    .detail-box ul{margin:.45rem 0 0;padding-inline-start:1.1rem}
    .detail-box li{margin-bottom:.38rem}
    .example-list{display:grid;gap:.65rem;margin-top:.75rem}
    .example-item{padding:.75rem .85rem;border-radius:14px;background:rgba(255,255,255,.03);border:1px solid rgba(155,240,255,.08)}
    .example-item strong{display:block;margin-bottom:.2rem;color:var(--tx)}
    .detail-meta{display:grid;gap:.8rem}
    .detail-pill{display:inline-flex;align-items:center;padding:.38rem .72rem;border-radius:999px;background:rgba(255,255,255,.03);border:1px solid rgba(155,240,255,.12);color:var(--pri);font-size:.74rem;font-weight:800}
    .cta-inline{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1rem}
    .price-request{margin-top:1rem;padding-top:1rem;border-top:1px dashed var(--bd)}
    .channel-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}
    .channel-card{border:1px dashed var(--bd);border-radius:16px;padding:1rem;background:rgba(255,255,255,.02)}
    .channel-card p{margin-bottom:.9rem}
    .mini-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}
    .mini-card{border:1px dashed var(--bd);border-radius:16px;padding:1rem;background:rgba(255,255,255,.02)}
    .cta-actions{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1rem}
    @media (max-width:760px){.top{align-items:flex-start}h1{max-width:none}.offer-detail-grid{grid-template-columns:1fr}}
  </style>
  <script src="/site-i18n.js" defer></script>
