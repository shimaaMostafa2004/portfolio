<body>
  <HomeLikeHeader />
  <main class="home-like-main">
  <div class="wrap">
    <div class="top">
      <div class="brand">النواة المعمارية</div>
      <div class="nav-actions">
        <a class="btn" href="/">الرئيسية</a>
        <a class="btn" href="/services/">الخدمات</a>
        <a class="btn btn-tab-active btn-flag-link" href="/offers/" aria-current="page">العروض <span class="btn-flag">HOT</span></a>
        <a class="btn" href="/blog/">المقالات</a>
        <a class="btn btn-primary" href="/#contact">تواصل</a>
      </div>
    </div>

    <section class="hero">
      <span class="eyebrow">العروض • اختر المسار المناسب</span>
      <h1>3 عروض واضحة حسب مرحلة مشروعك، بدل أن تبدأ بشكل مرتبك</h1>
      <p class="lead">ليس كل مشروع يحتاج نفس نوع العمل. أحيانًا تحتاج MVP سريعًا، وأحيانًا تحتاج سيستمًا متكاملًا من البداية، وأحيانًا يكون لديك نظام قائم يحتاج تطويرًا ودعمًا مستمرًا. هذه الصفحة تساعدك تختار العرض الأقرب لاحتياجك.</p>
    </section>

    <section class="section">
      <div class="section-kicker">نظرة سريعة</div>
      <h2>العروض المناسبة</h2>
      <p>لو تريد مقارنة سريعة، فهذه هي الفروق الأساسية. وبعدها ستجد تحتها شرحًا أعمق لكل عرض على حدة.</p>
      <div class="offers-grid">
        <article class="offer-card">
          <span class="offer-badge">MVP</span>
          <h3>إطلاق MVP</h3>
          <p class="offer-sub">مناسب إذا كنت تريد اختبار الفكرة بسرعة، لكن بأساس تقني محترم.</p>
          <ul>
            <li>تحليل مختصر وواضح للنطاق الأول</li>
            <li>Backend وAPI للوظائف الأساسية</li>
            <li>لوحة إدارة بسيطة أو تشغيلية حسب الحاجة</li>
            <li>ترتيب الأولويات لتقليل الهدر</li>
          </ul>
          <div class="price-note">
            <p><strong>مناسب لمن:</strong> الشركات الناشئة، الفكرة الجديدة، النسخة الأولى.</p>
          </div>
          <a class="offer-link" href="#offer-mvp">تفاصيل العرض</a>
        </article>

        <article class="offer-card featured">
          <span class="offer-badge">SYSTEM BUILD</span>
          <h3>بناء سيستم متكامل</h3>
          <p class="offer-sub">مناسب إذا كان عندك عمليات واضحة، مستخدمون وصلاحيات، وتحتاج نظامًا يخدم العمل فعليًا.</p>
          <ul>
            <li>تحليل العمليات وتحويلها إلى متطلبات</li>
            <li>تصميم قاعدة البيانات والبنية الخلفية</li>
            <li>بناء API ولوحات الإدارة والتقارير الأساسية</li>
            <li>تهيئة أفضل للتوسع من البداية</li>
          </ul>
          <div class="price-note">
            <p><strong>مناسب لمن:</strong> الشركات التشغيلية، SaaS، الحجوزات، الطلبات، الأنظمة الداخلية.</p>
          </div>
          <a class="offer-link" href="#offer-build">تفاصيل العرض</a>
        </article>

        <article class="offer-card">
          <span class="offer-badge">ONGOING SUPPORT</span>
          <h3>تطوير ودعم مستمر</h3>
          <p class="offer-sub">مناسب إذا كان لديك نظام قائم وتحتاج شخصًا يطوره ويثبّت تشغيله بدل الحلول المؤقتة.</p>
          <ul>
            <li>إضافة خصائص وتحسينات جديدة</li>
            <li>تحسين الأداء والاستقرار</li>
            <li>تنظيف أجزاء مرهقة في النظام</li>
            <li>متابعة ما بعد الإطلاق والدعم الفني</li>
          </ul>
          <div class="price-note">
            <p><strong>مناسب لمن:</strong> المنتجات القائمة، الأنظمة المتعبة، فرق تحتاج شريكًا تقنيًا مستمرًا.</p>
          </div>
          <a class="offer-link" href="#offer-support">تفاصيل العرض</a>
        </article>
      </div>
    </section>

    <section id="offer-mvp" class="offer-detail">
      <div class="section-kicker">Offer 01</div>
      <h2>إطلاق MVP</h2>
      <div class="offer-detail-grid">
        <div class="detail-box">
          <p>هذا العرض مناسب عندما تكون الفكرة موجودة، لكنك لا تريد أن تستهلك كل الوقت والميزانية في نسخة ضخمة قبل أن تختبر السوق أو الاستخدام الفعلي. هنا نركّز على بناء النسخة الأولى التي تحمل جوهر المنتج، وتسمح لك أن تبدأ بشكل صحيح بدل البدء بشكل سريع ثم إعادة كل شيء لاحقًا.</p>
          <p>الهدف من هذا العرض ليس أن يكون "أرخص نسخة" فقط، بل أن يكون <strong>أذكى نقطة بداية</strong>: وظائف أساسية واضحة، بنية خلفية نظيفة، وإطلاق يمكن البناء عليه.</p>
          <ul>
            <li>تحليل نطاق الإصدار الأول فقط</li>
            <li>ترتيب الأولويات وفصل الضروري عن المؤجل</li>
            <li>بناء Backend وAPI والبيانات الأساسية</li>
            <li>لوحة تشغيل أو إدارة بسيطة حسب الحاجة</li>
            <li>خطة واضحة لما بعد أول إطلاق</li>
          </ul>
          <div class="price-request">
            <p><strong>اطلب تسعير هذا العرض:</strong> اختر القناة المناسبة وسأفتح لك رسالة جاهزة بالتفاصيل المطلوبة.</p>
            <div class="cta-inline">
              <a class="btn btn-primary" href="mailto:info@abdotaher.me?subject=%D8%B7%D9%84%D8%A8%20%D8%AA%D8%B3%D8%B9%D9%8A%D8%B1%20-%20%D8%A5%D8%B7%D9%84%D8%A7%D9%82%20MVP&body=%D8%A7%D9%84%D8%B3%D9%84%D8%A7%D9%85%20%D8%B9%D9%84%D9%8A%D9%83%D9%85%D8%8C%0A%0A%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%AA%D8%B3%D8%B9%D9%8A%D8%B1%20%D8%B9%D8%B1%D8%B6%20%D8%A5%D8%B7%D9%84%D8%A7%D9%82%20MVP.%0A%0A%D8%AA%D9%81%D8%A7%D8%B5%D9%8A%D9%84%20%D8%A7%D9%84%D9%85%D8%B4%D8%B1%D9%88%D8%B9%3A%0A-%20%D9%86%D9%88%D8%B9%20%D8%A7%D9%84%D9%85%D8%B4%D8%B1%D9%88%D8%B9%3A%0A-%20%D9%81%D9%83%D8%B1%D8%A9%20%D9%85%D8%AE%D8%AA%D8%B5%D8%B1%D8%A9%3A%0A-%20%D8%A3%D9%87%D9%85%20%D8%A7%D9%84%D9%88%D8%B8%D8%A7%D8%A6%D9%81%20%D9%81%D9%8A%20%D8%A7%D9%84%D9%86%D8%B3%D8%AE%D8%A9%20%D8%A7%D9%84%D8%A3%D9%88%D9%84%D9%89%3A%0A-%20%D9%87%D9%84%20%D9%8A%D9%88%D8%AC%D8%AF%20%D9%84%D9%88%D8%AD%D8%A9%20%D8%A5%D8%AF%D8%A7%D8%B1%D8%A9%D8%9F%0A-%20%D9%87%D9%84%20%D9%87%D9%88%20%D9%88%D9%8A%D8%A8%20%D9%81%D9%82%D8%B7%20%D8%A3%D9%85%20%D9%8A%D9%88%D8%AC%D8%AF%20%D9%85%D9%88%D8%A8%D8%A7%D9%8A%D9%84%D8%9F%0A-%20%D8%A7%D9%84%D9%85%D8%AF%D8%A9%20%D8%A7%D9%84%D9%85%D8%AA%D9%88%D9%82%D8%B9%D8%A9%20%D9%84%D8%AF%D9%8A%D9%83%3A%0A-%20%D8%A3%D9%8A%20%D8%B1%D9%88%D8%A7%D8%A8%D8%B7%20%D8%A3%D9%88%20%D9%85%D8%B1%D8%A7%D8%AC%D8%B9%20%D9%85%D9%87%D9%85%D8%A9%3A">اطلب السعر عبر البريد</a>
              <a class="btn" href="https://wa.me/201008275881?text=%D8%A7%D9%84%D8%B3%D9%84%D8%A7%D9%85%20%D8%B9%D9%84%D9%8A%D9%83%D9%85%D8%8C%0A%D8%A3%D8%B1%D9%8A%D8%AF%20%D8%AA%D8%B3%D8%B9%D9%8A%D8%B1%20%D8%B9%D8%B1%D8%B6%20%D8%A5%D8%B7%D9%84%D8%A7%D9%82%20MVP.%0A%0A%D8%AA%D9%81%D8%A7%D8%B5%D9%8A%D9%84%20%D8%A7%D9%84%D9%85%D8%B4%D8%B1%D9%88%D8%B9%3A%0A-%20%D9%86%D9%88%D8%B9%20%D8%A7%D9%84%D9%85%D8%B4%D8%B1%D9%88%D8%B9%3A%0A-%20%D9%81%D9%83%D8%B1%D8%A9%20%D9%85%D8%AE%D8%AA%D8%B5%D8%B1%D8%A9%3A%0A-%20%D8%A3%D9%87%D9%85%20%D8%A7%D9%84%D9%88%D8%B8%D8%A7%D8%A6%D9%81%20%D9%81%D9%8A%20%D8%A7%D9%84%D9%86%D8%B3%D8%AE%D8%A9%20%D8%A7%D9%84%D8%A3%D9%88%D9%84%D9%89%3A%0A-%20%D9%87%D9%84%20%D9%8A%D9%88%D8%AC%D8%AF%20%D9%84%D9%88%D8%AD%D8%A9%20%D8%A5%D8%AF%D8%A7%D8%B1%D8%A9%D8%9F%0A-%20%D9%87%D9%84%20%D9%87%D9%88%20%D9%88%D9%8A%D8%A8%20%D9%81%D9%82%D8%B7%20%D8%A3%D9%85%20%D9%8A%D9%88%D8%AC%D8%AF%20%D9%85%D9%88%D8%A8%D8%A7%D9%8A%D9%84%D8%9F%0A-%20%D8%A7%D9%84%D9%85%D8%AF%D8%A9%20%D8%A7%D9%84%D9%85%D8%AA%D9%88%D9%82%D8%B9%D8%A9%20%D9%84%D8%AF%D9%8A%D9%83%3A%0A-%20%D8%A3%D9%8A%20%D8%B1%D9%88%D8%A7%D8%A8%D8%B7%20%D8%A3%D9%88%20%D9%85%D8%B1%D8%A7%D8%AC%D8%B9%20%D9%85%D9%87%D9%85%D8%A9%3A">اطلب السعر عبر واتساب</a>
            </div>
          </div>
          <div class="cta-inline">
            <a class="btn btn-primary" href="mailto:info@abdotaher.me?subject=MVP Offer">ابدأ بهذا العرض</a>
            <a class="btn" href="/estimating-mvp-cost-and-scope/">اقرأ عن تقدير MVP</a>
          </div>
        </div>
        <div class="detail-meta">
          <div class="detail-box">
            <span class="detail-pill">الأفضل إذا كنت</span>
            <p>تختبر فكرة جديدة، تطلق منتجًا لأول مرة، أو تريد الدخول للسوق بسرعة لكن بقاعدة تقنية محترمة.</p>
          </div>
          <div class="detail-box">
            <span class="detail-pill">النتيجة المتوقعة</span>
            <p>نسخة أولى واضحة ومستخدمة فعليًا، بدل مشروع كبير يتأخر دون اختبار حقيقي.</p>
          </div>
          <div class="detail-box">
            <span class="detail-pill">أمثلة مناسبة</span>
            <div class="example-list">
