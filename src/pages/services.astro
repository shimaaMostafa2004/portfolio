  <meta property="og:url" content="https://abdotaher.me/services/"/>
  <meta property="og:image" content="https://abdotaher.me/image.png"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="خدمات Backend وتطوير الأنظمة"/>
  <meta name="twitter:description" content="بناء الأنظمة من الصفر، تطوير MVP، وإدارة التشغيل والتحسين."/>
  <meta name="twitter:image" content="https://abdotaher.me/image.png"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet"/>
  <script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Backend Engineering Services","provider":{"@type":"Person","name":"Abdulrahman Taher","url":"https://abdotaher.me/"},"serviceType":"Backend Development, API Architecture, MVP Delivery, Operations Support","areaServed":["Egypt","Saudi Arabia","United Arab Emirates","Qatar","Kuwait","Bahrain","Oman"],"inLanguage":"ar"}</script>
  <script src="/site-i18n.js" defer></script>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/image.png"/>
  <link rel="apple-touch-icon" href="/image.png"/>
  <style>
    .services-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.25rem;
      display: grid;
      gap: 1rem;
    }

    .hero,
    .section,
    .cta {
      background: rgba(30, 25, 51, 0.9);
      border: 1px solid rgba(112, 213, 230, 0.16);
      border-radius: 22px;
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
      padding: 1.45rem;
    }

    .hero {
      background: linear-gradient(135deg, rgba(155, 240, 255, 0.08), rgba(30, 25, 51, 0.95) 45%);
    }

    .kicker {
      margin: 0;
      color: #8ff700;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .hero h1 {
      margin: 0.5rem 0 0;
      font-size: clamp(1.85rem, 4.8vw, 3rem);
      line-height: 1.3;
      max-width: 18ch;
      color: #ece6ff;
    }

    .hero p,
    .section p,
    .offer p,
    .step p,
    .mini p,
    .proof p,
    .link-card span {
      color: rgba(231, 222, 255, 0.78);
      line-height: 1.85;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1rem;
      align-items: start;
      margin-top: 0.8rem;
    }

    .hero-list,
    .offer ul,
    .mini ul {
      margin: 0.8rem 0 0;
      padding-inline-start: 1.1rem;
    }

    .hero-list li,
    .offer li,
    .mini li {
      color: rgba(231, 222, 255, 0.76);
      margin-bottom: 0.35rem;
    }

    .cta-actions {
      display: flex;
      gap: 0.65rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .btn {
      display: inline-block;
      padding: 0.62rem 1rem;
      border-radius: 999px;
      border: 1px solid rgba(112, 213, 230, 0.18);
      color: #9bf0ff;
      text-decoration: none;
      font-size: 0.74rem;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      font-weight: 800;
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      background: rgba(155, 240, 255, 0.09);
      border-color: rgba(155, 240, 255, 0.38);
    }

    .btn.primary {
      background: linear-gradient(135deg, #9bf0ff, #7de6ff);
      color: #042129;
      border-color: transparent;
    }

    .section-head {
      margin-bottom: 0.9rem;
    }

    .section-head h2 {
      margin: 0.35rem 0 0;
      font-size: 1.5rem;
      color: #ece6ff;
      line-height: 1.45;
    }

    .grid,
    .proof-list,
    .steps,
    .link-grid,
    .result-grid {
      display: grid;
      gap: 0.9rem;
    }

    .grid,
    .proof-list,
    .steps,
    .link-grid,
    .result-grid {
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    }

    .offer,
    .proof,
    .step,
    .mini,
    .result-card,
    .link-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px dashed rgba(112, 213, 230, 0.2);
      border-radius: 16px;
      padding: 1rem;
    }

    .offer h3,
    .proof h3 {
      margin: 0;
      color: #ece6ff;
      font-size: 1.06rem;
    }

    .split {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 0.9rem;
      align-items: start;
    }

    .result-card strong {
      display: block;
      color: #9bf0ff;
      margin-bottom: 0.35rem;
      font-size: 1.15rem;
    }

    .link-card {
      text-decoration: none;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .link-card strong {
      color: #9bf0ff;
      display: block;
      margin-bottom: 0.3rem;
    }

    .link-card:hover {
      transform: translateY(-3px);
      border-color: rgba(155, 240, 255, 0.4);
    }

    .cta h2 {
      margin: 0;
      font-size: 1.5rem;
      line-height: 1.5;
      color: #ece6ff;
    }

    @media (max-width: 1024px) {
      .services-wrap {
        padding: 1rem;
      }

      .hero,
      .section,
      .cta {
        padding: 1.2rem;
      }

      .grid,
      .proof-list,
      .steps,
      .link-grid,
      .result-grid {
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      }
    }

    @media (max-width: 840px) {
      .hero-grid,
      .split {
        grid-template-columns: 1fr;
      }

      .hero h1 {
        max-width: none;
      }
    }

    @media (max-width: 760px) {
      .services-wrap { padding: 1rem; }

      .btn {
        width: 100%;
        text-align: center;
      }

      .cta-actions {
        gap: 0.5rem;
      }
    }

    @media (max-width: 520px) {
      .hero h1 {
        font-size: clamp(1.5rem, 8vw, 2rem);
      }

      .section-head h2,
      .cta h2 {
        font-size: 1.3rem;
      }

      .offer,
      .proof,
      .step,
      .mini,
      .result-card,
      .link-card {
        padding: 0.85rem;
      }
    }
  </style>
</head>
<body>
  <HomeLikeHeader />
  <main class="home-like-main">
    <div class="services-wrap">
      <section class="hero" aria-labelledby="services-heading">
        <p class="kicker">الخدمات • الباك-إند والأنظمة</p>
        <h1 id="services-heading">أبني لك النظام من الصفر وأطوره بعد الإطلاق بثبات ووضوح</h1>
        <div class="hero-grid">
          <div>
            <p>إذا كنت صاحب مشروع أو شركة وتريد موقعًا أو سيستمًا يخدم العمل فعلًا، فالهدف ليس مجرد كود، بل بناء أساس تقني واضح يمكن الاعتماد عليه والتوسع فوقه.</p>
            <ul class="hero-list">
              <li>بناء موقع أو سيستم أو MVP من البداية</li>
              <li>تصميم Backend وAPI وقاعدة بيانات منظمة</li>
              <li>دعم وتحسين النظام بعد الإطلاق</li>
            </ul>
            <div class="cta-actions">
              <a class="btn primary" href="/#contact">ابدأ التواصل</a>
              <a class="btn" href="https://wa.me/201008275881">واتساب</a>
              <a class="btn" href="/offers/">العروض</a>
            </div>
          </div>
          <aside class="proof">
            <h3>ماذا ستحصل فعليًا؟</h3>
            <p>تنفيذ واضح، قرارات تقنية منطقية، وتسليمات تدريجية قابلة للقياس بدل البناء العشوائي الذي يستهلك وقت وميزانية.</p>
          </aside>
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <p class="kicker">الخدمات الأساسية</p>
          <h2>ما الذي أقدمه لك في المشاريع التشغيلية؟</h2>
        </div>
        <div class="grid">
          <article class="offer">
            <h3>بناء المنتج من الصفر</h3>
            <p>تحويل الفكرة إلى نظام عملي منظم: متطلبات واضحة، قاعدة بيانات نظيفة، وواجهات API قابلة للتوسع.</p>
          </article>
          <article class="offer">
            <h3>تطوير MVP بذكاء</h3>
            <p>إطلاق سريع دون تكديس تعقيد تقني مبكر مع اختيار أولويات الإصدار الأول بدقة.</p>
          </article>
          <article class="offer">
            <h3>تحسين الأنظمة القائمة</h3>
            <p>ترتيب الـ flows، خفض الأعطال، وتوسيع النظام الحالي بدلاً من الترقيع المستمر.</p>
          </article>
          <article class="offer">
            <h3>أداء وتشغيل</h3>
            <p>تحسين استعلامات البيانات والكاش ومراقبة الخدمة للحفاظ على استقرار الأداء مع نمو الاستخدام.</p>
          </article>
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <p class="kicker">النتيجة</p>
          <h2>لماذا هذا المسار عملي لأصحاب المشاريع؟</h2>
        </div>
        <div class="result-grid">
          <article class="result-card"><strong>وضوح في البداية</strong><p>قبل التنفيذ نحدد ما يجب بناؤه فعلًا.</p></article>
          <article class="result-card"><strong>إطلاق أسرع</strong><p>تنفيذ مرحلي يختصر الوقت ويقلل ارتباك الفريق.</p></article>
          <article class="result-card"><strong>استمرارية أفضل</strong><p>النظام يبقى قابل للتطوير بدل إعادة البناء كل فترة.</p></article>
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <p class="kicker">طريقة العمل</p>
          <h2>كيف نمشي من الفكرة إلى التنفيذ؟</h2>
        </div>
        <div class="steps">
          <article class="step"><strong>1. فهم الاحتياج</strong><p>نحدد طبيعة المشروع ومسار القيمة الحقيقي.</p></article>
          <article class="step"><strong>2. تحديد النطاق</strong><p>تقسيم التنفيذ إلى مراحل واضحة وقابلة للقياس.</p></article>
          <article class="step"><strong>3. التنفيذ المرحلي</strong><p>بناء backend وواجهات API والعمليات الأساسية.</p></article>
          <article class="step"><strong>4. ما بعد الإطلاق</strong><p>دعم وتحسين مستمر حسب الاستخدام الفعلي.</p></article>
        </div>
      </section>

      <section class="section">
        <div class="section-head">
          <p class="kicker">صفحات مرتبطة</p>
          <h2>روابط تساعدك تقرر أسرع</h2>
        </div>
        <div class="link-grid">
          <a class="link-card" href="/offers/"><strong>صفحة العروض</strong><span>3 مسارات واضحة حسب مرحلة مشروعك.</span></a>
          <a class="link-card" href="/web-system-development-gcc/"><strong>دليل موقع أم سيستم</strong><span>يساعدك تحسم نوع المنتج المناسب.</span></a>
          <a class="link-card" href="/how-to-choose-backend-engineer/"><strong>كيف تختار Backend Engineer</strong><span>أسئلة عملية قبل التعاقد والتنفيذ.</span></a>
          <a class="link-card" href="/projects/"><strong>معرض الأعمال</strong><span>اطلع على مشاريع منفذة وسياقاتها.</span></a>
        </div>
      </section>

      <section class="cta">
        <h2>إذا كنت تريد تنفيذًا محترفًا من البداية أو إعادة تنظيم نظام قائم، نقدر نبدأ بخطوة واضحة الآن.</h2>
        <p>راسلني مباشرة لنحدد نقطة البداية المناسبة لمشروعك والزمن المتوقع للتنفيذ.</p>
        <div class="cta-actions">
          <a class="btn primary" href="mailto:abdotaher093@gmail.com">راسلني عبر البريد</a>
          <a class="btn" href="https://wa.me/201008275881">تواصل واتساب</a>
        </div>
      </section>
    </div>
  </main>
  <HomeLikeFooter />
</body>
</html>
