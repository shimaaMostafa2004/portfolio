  <style>
    :root{--bg:#0d0b1a;--card:#1e1933;--soft:rgba(30,25,51,.88);--bd:rgba(112,213,230,.14);--tx:#e7deff;--mut:rgba(231,222,255,.72);--pri:#9bf0ff;--acc:#8ff700}
    *{box-sizing:border-box}
    body{margin:0;background:
      radial-gradient(circle at top right, rgba(155,240,255,.08), transparent 30%),
      radial-gradient(circle at bottom left, rgba(143,247,0,.06), transparent 28%),
      var(--bg);color:var(--tx);font-family:'Cairo',sans-serif;line-height:1.85;padding-top:6.5rem}
    .wrap{max-width:1120px;margin:auto;padding:1.25rem}
    .top{position:fixed;top:.5rem;left:50%;transform:translateX(-50%);z-index:100;width:min(calc(100% - 1rem),1120px);display:flex;justify-content:space-between;align-items:center;padding:.9rem 1rem;background:rgba(13,11,26,.88);backdrop-filter:blur(18px);border:1px solid var(--bd);border-radius:18px;box-shadow:0 16px 40px rgba(0,0,0,.22)}
    .brand{font-family:'Space Grotesk',sans-serif;color:var(--pri);font-weight:700;letter-spacing:.08em}
    .nav-actions{display:flex;gap:.6rem;flex-wrap:wrap}
    .btn{display:inline-block;padding:.65rem 1.1rem;border-radius:999px;border:1px solid var(--bd);color:var(--pri);text-decoration:none}
    .btn-flag-link{display:inline-flex;align-items:center;gap:.45rem}
    .btn-flag{display:inline-flex;align-items:center;justify-content:center;padding:.22rem .48rem;border-radius:999px;font-size:.52rem;font-weight:900;letter-spacing:.12em;color:#ffe9d6;background:linear-gradient(135deg,#ff7a18,#ff3d00);box-shadow:0 0 18px rgba(255,90,0,.28)}
    .btn-tab-active{background:rgba(155,240,255,.12);border-color:rgba(155,240,255,.34);color:var(--tx);box-shadow:inset 0 0 0 1px rgba(155,240,255,.08)}
    .btn-primary{background:var(--pri);color:#001f24;border-color:transparent;font-weight:800}
    .hero,.section,.cta,.offer,.proof{background:var(--soft);border:1px solid var(--bd);border-radius:20px;box-shadow:0 18px 48px rgba(0,0,0,.18)}
    .hero,.section,.cta{padding:1.4rem;margin-top:1rem}
    .hero{padding:1.7rem;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-30px;left:-40px;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle, rgba(155,240,255,.18), transparent 70%)}
    .hero::after{content:'';position:absolute;bottom:-55px;right:-35px;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle, rgba(143,247,0,.08), transparent 70%)}
    .eyebrow{display:inline-flex;align-items:center;gap:.55rem;padding:.45rem .8rem;border-radius:999px;border:1px solid rgba(155,240,255,.14);background:rgba(255,255,255,.02);color:var(--pri);font-size:.78rem;font-weight:700}
    h1{margin:.85rem 0;font-size:clamp(1.95rem,4.6vw,3.3rem);line-height:1.3;max-width:15ch}
    h2{margin:.1rem 0 .8rem;font-size:1.45rem}
    h3{margin:.1rem 0 .6rem;font-size:1.08rem}
    p,li{color:var(--mut)}
    strong{color:var(--tx)}
    a{color:var(--pri);text-decoration:none}
    .lead{font-size:1.03rem;max-width:66ch}
    .section-header{display:flex;justify-content:space-between;align-items:flex-end;gap:1rem;margin-bottom:.85rem}
    .kicker{font-size:.75rem;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--acc)}
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}
    .hero-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:1rem;align-items:start}
    .offer{padding:1.1rem}
    .offer ul{margin:.45rem 0 0;padding-inline-start:1.1rem}
    .offer li{margin-bottom:.35rem}
    .steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem}
    .step,.mini-card,.link-card,.result-card,.proof{border:1px dashed var(--bd);border-radius:16px;padding:1rem;background:rgba(255,255,255,.02)}
    .split{display:grid;grid-template-columns:1.15fr .85fr;gap:1rem;align-items:start}
    .result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.9rem;margin-top:1rem}
    .result-card strong{display:block;font-size:1.7rem;color:var(--pri);margin-bottom:.35rem}
    .hero-list{margin:.8rem 0 0;padding-inline-start:1.1rem}
    .hero-list li{margin-bottom:.35rem}
    .proof-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.9rem}
    .proof h3{margin-bottom:.35rem}
    .link-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.85rem}
    .link-card strong{display:block;margin-bottom:.35rem}
    .cta{background:linear-gradient(135deg, rgba(155,240,255,.07), rgba(30,25,51,.92) 40%), var(--soft)}
    .cta-actions{display:flex;gap:.8rem;flex-wrap:wrap;margin-top:1rem}
    @media (max-width:760px){
      .hero-grid,
      .split{grid-template-columns:1fr}
      h1{max-width:none}
      .top{align-items:flex-start}
    }
  </style>
