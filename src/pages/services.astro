  <meta name="robots" content="index, follow, max-image-preview:large"/>
  <link rel="canonical" href="https://abdotaher.me/services/"/>
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="خدمات Backend وتطوير الأنظمة | عبدالرحمن طاهر"/>
