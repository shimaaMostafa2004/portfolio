---
import HomeLikeHeader from '../components/HomeLikeHeader.astro';
import HomeLikeFooter from '../components/HomeLikeFooter.astro';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>خدمات Backend وتطوير الأنظمة | عبدالرحمن طاهر</title>
  <meta name="description" content="خدمات احترافية لبناء Backend وAPI وأنظمة تشغيلية واضحة: من MVP إلى الإطلاق والتحسين المستمر."/>
