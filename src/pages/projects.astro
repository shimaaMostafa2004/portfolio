---
import HomeLikeHeader from '../components/HomeLikeHeader.astro';
import HomeLikeFooter from '../components/HomeLikeFooter.astro';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>معرض الأعمال | عبدالرحمن طاهر</title>
  <meta name="description" content="استعرض مشاريع عبدالرحمن طاهر في الأنظمة الخلفية ومنتجات التشغيل وتطبيقات الموبايل مع وصف مختصر وتقنيات التنفيذ."/>
  <meta name="robots" content="index, follow, max-image-preview:large"/>
  <link rel="canonical" href="https://abdotaher.me/projects/"/>
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="معرض الأعمال | عبدالرحمن طاهر"/>
  <meta property="og:description" content="كل المشاريع والتطبيقات في صفحة واحدة مع عرض واضح للتقنيات والنتائج."/>
  <meta property="og:url" content="https://abdotaher.me/projects/"/>
  <meta property="og:image" content="https://abdotaher.me/image.png"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="معرض الأعمال | عبدالرحمن طاهر"/>
  <meta name="twitter:description" content="كل المشاريع والتطبيقات في صفحة واحدة."/>
  <meta name="twitter:image" content="https://abdotaher.me/image.png"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet"/>
  <script src="/site-i18n.js" defer></script>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/image.png"/>
  <link rel="apple-touch-icon" href="/image.png"/>
  <style>
    .projects-wrap {
      max-width: 1160px;
      margin: 0 auto;
      padding: 1.25rem;
    }

    .projects-hero {
      background: linear-gradient(135deg, rgba(155, 240, 255, 0.08), rgba(30, 25, 51, 0.96) 45%);
      border: 1px solid rgba(112, 213, 230, 0.18);
      border-radius: 22px;
      padding: 1.5rem;
      box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
    }

    .projects-kicker {
      color: #8ff700;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      font-weight: 800;
      text-transform: uppercase;
      margin: 0;
    }

    .projects-hero h1 {
      margin: 0.45rem 0 0;
      font-size: clamp(1.7rem, 4vw, 2.5rem);
      line-height: 1.3;
      color: #e7deff;
    }

    .projects-hero p {
      margin: 0.65rem 0 0;
      color: rgba(231, 222, 255, 0.78);
      max-width: 74ch;
    }

    .projects-grid {
      margin-top: 1.2rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 1rem;
    }

    .project-card {
      background: rgba(30, 25, 51, 0.92);
      border: 1px solid rgba(112, 213, 230, 0.16);
      border-radius: 18px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .project-card:hover {
      transform: translateY(-4px);
      border-color: rgba(155, 240, 255, 0.44);
      box-shadow: 0 24px 56px rgba(0, 0, 0, 0.32);
    }

    .project-image {
      aspect-ratio: 16 / 9;
      background: rgba(255, 255, 255, 0.03);
      overflow: hidden;
    }

    .project-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-body {
      padding: 1rem;
      display: grid;
      gap: 0.6rem;
    }

    .project-title {
      margin: 0;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.65rem;
      color: #e7deff;
      font-size: 1rem;
      line-height: 1.45;
    }

    .project-title a {
      color: #9bf0ff;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      border-radius: 8px;
    }

    .project-title a:hover {
      color: #ccf8ff;
    }

    .project-desc {
      margin: 0;
      color: rgba(231, 222, 255, 0.76);
      font-size: 0.88rem;
      line-height: 1.75;
    }

    .project-tags {
      font-size: 0.63rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8ff700;
    }

    .projects-state {
      margin-top: 1rem;
      background: rgba(255, 255, 255, 0.03);
      border: 1px dashed rgba(112, 213, 230, 0.22);
      border-radius: 14px;
      padding: 0.95rem 1rem;
      color: rgba(231, 222, 255, 0.74);
      font-size: 0.9rem;
    }

    .projects-state.error {
      border-color: rgba(255, 122, 122, 0.42);
      color: #ffd1d1;
    }

    @media (max-width: 1024px) {
      .projects-wrap {
        padding: 1rem;
      }

      .projects-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      }
    }

    @media (max-width: 760px) {
      .projects-wrap { padding: 1rem; }

      .projects-hero,
      .project-body {
        padding: 0.95rem;
      }

      .projects-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 520px) {
      .projects-hero h1 {
        font-size: clamp(1.45rem, 8vw, 1.95rem);
      }

      .project-title {
        font-size: 0.95rem;
      }

      .project-desc {
        font-size: 0.84rem;
      }
    }
  </style>
</head>
<body>
  <HomeLikeHeader />
  <main class="home-like-main">
    <div class="projects-wrap">
      <section class="projects-hero" aria-labelledby="projects-heading">
        <p class="projects-kicker">Portfolio</p>
        <h1 id="projects-heading" data-i18n="projects.hero_title">معرض أعمال يوضح التنفيذ الفعلي للمشاريع</h1>
        <p data-i18n="projects.hero_desc">صفحة تجمع المشاريع في مكان واحد مع وصف مختصر للتقنيات وسياق الاستخدام حتى ترى نوع الأعمال التي تم تنفيذها فعليًا.</p>
      </section>

      <div id="projects-state" class="projects-state" role="status" aria-live="polite" data-i18n="projects.loading">جاري تحميل المشاريع...</div>
      <section id="projects-grid" class="projects-grid" role="list" aria-label="Projects gallery"></section>
    </div>

    <script>
      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/\"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }

      function normalizeProject(project) {
        return {
          name: project.name || project.title || project.project || '',
          image: project.image || project.image_url || project.img || '',
          altAr: project.altAr || project.alt_ar || project.altar || '',
          altEn: project.altEn || project.alt_en || project.alten || '',
          descAr: project.descAr || project.desc_ar || project.description_ar || '',
          descEn: project.descEn || project.desc_en || project.description_en || '',
          tags: project.tags || project.stack || '',
          link: project.link || project.url || project.href || ''
        };
      }

      function renderProjects(projects) {
        const grid = document.getElementById('projects-grid');
        const state = document.getElementById('projects-state');
        if (!grid || !state) return;

        const lang = window.siteI18n?.getLang?.() || (document.body.classList.contains('lang-en') ? 'en' : 'ar');
        const valid = projects.filter((item) => item && item.name && item.image);

        if (!valid.length) {
          state.classList.add('error');
          state.textContent = window.siteI18n?.t?.('projects.empty', lang === 'en' ? 'No projects available right now.' : 'لا توجد مشاريع متاحة حاليًا.')
            || (lang === 'en' ? 'No projects available right now.' : 'لا توجد مشاريع متاحة حاليًا.');
          return;
        }

        state.style.display = 'none';

        grid.innerHTML = valid.map((project) => {
          const safeName = escapeHtml(project.name);
          const safeImage = escapeHtml(project.image);
          const currentAlt = lang === 'en' ? (project.altEn || project.altAr || project.name) : (project.altAr || project.altEn || project.name);
          const currentDesc = lang === 'en' ? (project.descEn || project.descAr || '') : (project.descAr || project.descEn || '');
          const safeAlt = escapeHtml(currentAlt);
          const safeDesc = escapeHtml(currentDesc);
          const safeTags = escapeHtml(project.tags || '');
          const safeLink = escapeHtml(project.link || '#');
          const isExternal = Boolean(project.link);

          return `
          <article class="project-card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication">
            <div class="project-image">
              <img src="${safeImage}" alt="${safeAlt}" width="560" height="315" loading="lazy" decoding="async" itemprop="image" />
            </div>
            <div class="project-body">
              <h2 class="project-title">
                <span itemprop="name">${safeName}</span>
                <a href="${safeLink}" ${isExternal ? 'target="_blank" rel="noopener noreferrer"' : ''} aria-label="${safeName}">
                  <span class="material-symbols-outlined" aria-hidden="true">open_in_new</span>
                </a>
              </h2>
              <p class="project-desc" itemprop="description">${safeDesc}</p>
              <div class="project-tags">${safeTags}</div>
            </div>
          </article>`;
        }).join('');
      }

      let sourceProjects = [];

      fetch('/projects.json', { cache: 'no-cache' })
        .then((res) => {
          if (!res.ok) throw new Error('Failed to fetch projects.json');
          return res.json();
        })
        .then((projects) => {
          sourceProjects = (projects || []).map(normalizeProject);
          renderProjects(sourceProjects);
        })
        .catch(() => {
          const state = document.getElementById('projects-state');
          if (state) {
            state.classList.add('error');
            const fallback = document.body.classList.contains('lang-en')
              ? 'Could not load projects data. Please try again later.'
              : 'تعذر تحميل بيانات المشاريع الآن. حاول مرة أخرى لاحقًا.';
            state.textContent = window.siteI18n?.t?.('projects.fetch_error', fallback) || fallback;
          }
        });

      window.addEventListener('site:lang-change', () => {
        if (sourceProjects.length) renderProjects(sourceProjects);
      });
    </script>
  </main>
  <HomeLikeFooter />
</body>
</html>
