        "desc_en": "A smart app for booking rides within cities safely and easily, with real-time driver tracking, map-based destination selection, preferred vehicle and payment method, and estimated fares.",
        "tags": "ANDROID // RIDE-HAILING",
        "link": "https://play.google.com/store/apps/details?id=com.alalmiya.ajeek"
      }
    ];

    fetch('./projects.json', { cache: 'no-cache' })
      .then((res) => {
        if (!res.ok) {
          throw new Error('Failed to fetch projects.json');
        }
        return res.json();
      })
      .then((projects) => {
        const source = Array.isArray(projects) && projects.length ? projects : PROJECTS_FALLBACK;
        renderProjects(source.map(normalizeProject));
      })
      .catch(() => {
        renderProjects(PROJECTS_FALLBACK.map(normalizeProject));
      });
  </script>
  </main>
  <HomeLikeFooter />
</body>
</html>
