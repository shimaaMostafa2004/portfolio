    <section id="projects-grid" class="grid" role="list" aria-live="polite"></section>
  </div>

  <script>
    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function normalizeProject(project) {
      return {
        name: project.name || project.title || project.project || '',
        image: project.image || project.image_url || project.img || '',
        altAr: project.altAr || project.alt_ar || project.altar || '',
        altEn: project.altEn || project.alt_en || project.alten || '',
        descAr: project.descAr || project.desc_ar || project.description_ar || '',
        descEn: project.descEn || project.desc_en || project.description_en || '',
        tags: project.tags || project.stack || '',
        link: project.link || project.url || project.href || ''
      };
    }

    function renderProjects(projects) {
      const grid = document.getElementById('projects-grid');
      if (!grid) return;

      const valid = projects.filter(item => item && item.name && item.image);
      grid.innerHTML = valid.map(project => {
        const safeName = escapeHtml(project.name);
        const safeImage = escapeHtml(project.image);
        const safeAltAr = escapeHtml(project.altAr || `${project.name} – مشروع`);
        const safeDescAr = escapeHtml(project.descAr || project.descEn || '');
        const safeTags = escapeHtml(project.tags || '');
        const safeLink = escapeHtml(project.link || '#');
        const isExternal = !!project.link;

        return `
        <article class="card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication">
          <div class="card-img">
            <img src="${safeImage}" alt="${safeAltAr}" width="400" height="180" loading="lazy" itemprop="image"/>
          </div>
          <div class="card-body">
            <h2 class="card-title">
              <span itemprop="name">${safeName}</span>
              <a href="${safeLink}" ${isExternal ? 'target="_blank" rel="noopener noreferrer"' : ''} aria-label="${safeName}">
                <span class="material-symbols-outlined" aria-hidden="true">open_in_new</span>
              </a>
            </h2>
            <p class="card-desc" itemprop="description">${safeDescAr}</p>
            <div class="card-tags">${safeTags}</div>
          </div>
        </article>`;
      }).join('');
    }

