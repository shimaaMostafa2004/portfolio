  function getVisitorRegion() {
    const params = new URLSearchParams(window.location.search);
    const forcedRegion = (params.get('region') || '').toLowerCase();
    const regionAliases = {
      eg: 'egypt',
      egypt: 'egypt',
      sa: 'saudi',
      saudi: 'saudi',
      'saudi-arabia': 'saudi',
      ksa: 'saudi',
      ae: 'uae',
      uae: 'uae',
      'united-arab-emirates': 'uae',
      qa: 'qatar',
      qatar: 'qatar',
      kw: 'kuwait',
      kuwait: 'kuwait',
      bh: 'bahrain',
      bahrain: 'bahrain',
      om: 'oman',
      oman: 'oman',
      gcc: 'gcc'
    };
    if (regionAliases[forcedRegion]) return regionAliases[forcedRegion];

    const forced = params.get('gcc');
    if (forced === '1') return 'gcc';
    if (forced === '0') return 'default';

    const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
    if (timezone === 'Africa/Cairo') return 'egypt';

    const locale = (navigator.language || '').toLowerCase();
    if (locale === 'ar-eg') return 'egypt';

    return 'saudi';
  }

  function isGccVisitor() {
    return new Set(['saudi', 'uae', 'qatar', 'kuwait', 'bahrain', 'oman', 'gcc']).has(getVisitorRegion());
  }

