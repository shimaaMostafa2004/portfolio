<script>
  function applyLangSideEffects(lang) {
    ['ar', 'en'].forEach(l => {
      const btn = document.getElementById('btn-' + l);
      const btnM = document.getElementById('btn-' + l + '-m');
      const active = l === lang;
      if (btn) {
        btn.classList.toggle('active', active);
        btn.setAttribute('aria-pressed', String(active));
      }
      if (btnM) {
        btnM.classList.toggle('active', active);
        btnM.setAttribute('aria-pressed', String(active));
      }
    });

    const visitorRegion = getVisitorRegion();
    const regionMeta = getRegionMeta(visitorRegion, lang);
    document.title = regionMeta.title;
    document.querySelector('meta[name="description"]').setAttribute('content', regionMeta.description);
    document.querySelector('meta[name="keywords"]').setAttribute('content', regionMeta.keywords);
    const ogTitle = document.querySelector('meta[property="og:title"]');
    const ogDescription = document.querySelector('meta[property="og:description"]');
    const twitterTitle = document.querySelector('meta[name="twitter:title"]');
    const twitterDescription = document.querySelector('meta[name="twitter:description"]');
    if (ogTitle) ogTitle.setAttribute('content', regionMeta.title);
    if (ogDescription) ogDescription.setAttribute('content', regionMeta.description);
    if (twitterTitle) twitterTitle.setAttribute('content', regionMeta.title);
    if (twitterDescription) twitterDescription.setAttribute('content', regionMeta.description);
    document.querySelectorAll('[data-alt-ar][data-alt-en]').forEach((image) => {
      image.setAttribute('alt', lang === 'en' ? image.getAttribute('data-alt-en') : image.getAttribute('data-alt-ar'));
    });
  }

  function setLang(lang) {
    if (window.siteI18n?.switchLanguage) {
      window.siteI18n.switchLanguage(lang);
    }
    applyLangSideEffects(lang);
    try {
      localStorage.setItem('preferred-lang', lang);
    } catch (e) {}
  }
  window.setLang = setLang;

  window.addEventListener('site:lang-change', (event) => {
    const lang = event?.detail?.lang || 'ar';
    applyLangSideEffects(lang);
  });

  (function () {
    try {
      const paramLang = new URLSearchParams(window.location.search).get('lang');
      if (paramLang === 'en' || paramLang === 'ar') {
        setLang(paramLang);
        return;
      }

      const saved = localStorage.getItem('preferred-lang');
      if (saved === 'en') {
        setLang('en');
        return;
      }

      setLang('ar');
    } catch (e) {}
  })();

