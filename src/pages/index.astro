  function applyGccVisibility() {
    const shouldShowGcc = isGccVisitor();
    document.querySelectorAll('.gcc-only').forEach((element) => {
      element.classList.toggle('region-hidden', !shouldShowGcc);
    });

    if (!shouldShowGcc && window.location.hash === '#gcc') {
      window.location.hash = '#contact';
    }
  }

  applyGccVisibility();

  function applyRegionContentVisibility() {
    const isNeutralDefault = getVisitorRegion() === 'default';
    document.querySelectorAll('[data-region-content]').forEach((element) => {
      element.classList.toggle('region-content-hidden', isNeutralDefault);
    });
  }

  applyRegionContentVisibility();

  function setupMotionReveal() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealSelectors = [
      '#about .panel',
      '#stack .chip',
      '#work .card',
      '#case-studies .case-study',
      '#experience .timeline-item',
      '#services .panel',
      '#gcc .card',
      '#blog .card',
      '.cta-banner',
      '#contact .contact-section',
      'section .section-label',
      'section .section-title'
    ];

    const revealTargets = Array.from(document.querySelectorAll(revealSelectors.join(',')));
    revealTargets.forEach((element, index) => {
      element.classList.add('motion-reveal');
      element.style.setProperty('--reveal-delay', `${Math.min((index % 8) * 70, 420)}ms`);

      if (prefersReducedMotion) {
        element.classList.add('is-visible');
      }
    });

    if (prefersReducedMotion) return;

    const revealObserver = new IntersectionObserver((entries, observerRef) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observerRef.unobserve(entry.target);
      });
    }, {
      threshold: 0.18,
      rootMargin: '0px 0px -8% 0px'
    });

    revealTargets.forEach((element) => revealObserver.observe(element));
  }

  setupMotionReveal();

  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"], .mobile-nav a[href^="#"]');

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
        });
      }
    });
  }, { threshold: 0.4 });

  sections.forEach(section => observer.observe(section));
</script>
</body>
</html>
