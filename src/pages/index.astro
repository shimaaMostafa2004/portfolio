    .btn-primary {
      background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dim));
      color: #001f24; padding: 0.8rem 2rem;
      border-radius: 9999px; font-weight: 800;
      font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
