  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function normalizeProject(project) {
    return {
      name: project.name || project.title || project.project || '',
      image: project.image || project.image_url || project.img || '',
      altAr: project.altAr || project.alt_ar || project.altar || '',
      altEn: project.altEn || project.alt_en || project.alten || '',
      descAr: project.descAr || project.desc_ar || project.description_ar || '',
      descEn: project.descEn || project.desc_en || project.description_en || '',
      impactAr: project.impactAr || project.impact_ar || '',
      impactEn: project.impactEn || project.impact_en || '',
      tags: project.tags || project.stack || '',
      link: project.link || project.url || project.href || ''
    };
  }

  function renderProjects(projects) {
    const grid = document.getElementById('projects-grid');
    if (!grid) return;

    const valid = projects.filter(item => item && item.name && item.image);
    grid.innerHTML = valid.map(project => {
      const safeName = escapeHtml(project.name);
      const safeImage = escapeHtml(project.image);
      const safeAltAr = escapeHtml(project.altAr || `${project.name} – مشروع`);
      const safeAltEn = escapeHtml(project.altEn || `${project.name} – project`);
      const currentAlt = document.body.classList.contains('lang-en') ? safeAltEn : safeAltAr;
      const safeDescAr = escapeHtml(project.descAr || '');
      const safeDescEn = escapeHtml(project.descEn || '');
      const safeImpactAr = escapeHtml(project.impactAr || '');
      const safeImpactEn = escapeHtml(project.impactEn || '');
      const safeTags = escapeHtml(project.tags || '');
      const safeLink = escapeHtml(project.link || '#');
      const isExternal = !!project.link;

      return `
      <article class="card" role="listitem" itemscope itemtype="https://schema.org/SoftwareApplication">
        <div class="card-img">
          <img src="${safeImage}" alt="${currentAlt}" data-alt-ar="${safeAltAr}" data-alt-en="${safeAltEn}" width="400" height="180" loading="lazy" decoding="async" itemprop="image"/>
        </div>
        <div class="card-body">
          <div class="card-title">
            <span itemprop="name">${safeName}</span>
            <a href="${safeLink}" ${isExternal ? 'target="_blank" rel="noopener noreferrer"' : ''} aria-label="${safeName}" style="display:inline-flex; align-items:center;">
              <span class="material-symbols-outlined" style="font-size:1rem; color:var(--c-primary);" aria-hidden="true">open_in_new</span>
            </a>
          </div>
          <p class="card-desc" itemprop="description">${document.body.classList.contains('lang-en') ? safeDescEn : safeDescAr}</p>
          ${safeImpactAr || safeImpactEn ? `
          <div class="project-impact">
            <strong>${document.body.classList.contains('lang-en') ? 'Impact:' : 'الأثر:'}</strong>
            <span>${document.body.classList.contains('lang-en') ? safeImpactEn : safeImpactAr}</span>
          </div>` : ''}
          <div class="card-tags">${safeTags}</div>
        </div>
      </article>`;
    }).join('');
  }

  renderProjects(PROJECTS_DATA.map(normalizeProject).slice(0, 3));

