      --c-text:    #e7deff;
      --c-muted:   rgba(231,222,255,0.5);
      --font-ar:   'Cairo', sans-serif;
      --font-en:   'Space Grotesk', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--c-bg);
      color: var(--c-text);
      font-family: var(--font-ar);
      line-height: 1.7;
      min-height: 100dvh;
    }

    img,
    svg,
    video {
      max-width: 100%;
      height: auto;
    }

    body.lang-en {
      font-family: var(--font-en);
      direction: ltr;
    }

    a:focus-visible,
    button:focus-visible {
      outline: 2px solid var(--c-accent);
      outline-offset: 2px;
      border-radius: 8px;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }

    header {
      position: fixed; top: 0; width: 100%; z-index: 100;
      background: rgba(13,11,26,0.75);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--c-border);
    }
    nav {
      max-width: 1280px; margin: auto;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.5rem; height: 4.5rem;
    }
    .nav-brand {
      font-family: var(--font-mono);
      color: var(--c-primary);
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .nav-links { display: flex; gap: 2rem; align-items: center; }
    .nav-links a {
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--c-muted); text-decoration: none;
      transition: color 0.25s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--c-primary); }
    .nav-flag-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }
    .nav-flag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.22rem 0.48rem;
      border-radius: 999px;
      font-size: 0.52rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      color: #ffe9d6;
      background: linear-gradient(135deg, #ff7a18, #ff3d00);
      box-shadow: 0 0 18px rgba(255, 90, 0, 0.28);
    }
    .nav-item {
      position: relative;
      display: flex;
      align-items: center;
      height: 100%;
    }
    .nav-trigger {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--c-muted);
      text-decoration: none;
      cursor: pointer;
      transition: color 0.25s;
    }
    .nav-trigger:hover,
    .nav-item:hover .nav-trigger { color: var(--c-primary); }
    .nav-dropdown {
      position: absolute;
      top: calc(100% + 0.75rem);
      inset-inline-start: 0;
      min-width: 320px;
      padding: 0.8rem;
      border: 1px solid var(--c-border);
      border-radius: 1rem;
      background: rgba(22,18,40,0.96);
      backdrop-filter: blur(18px);
      box-shadow: 0 18px 50px rgba(0,0,0,0.35);
      opacity: 0;
      visibility: hidden;
      transform: translateY(6px);
      transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
      z-index: 120;
    }
    .nav-item:hover .nav-dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .nav-dropdown a {
      display: block;
      padding: 0.75rem 0.85rem;
      border-radius: 0.9rem;
      letter-spacing: normal;
      text-transform: none;
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--c-text);
      border: 1px solid transparent;
      background: rgba(255,255,255,0.01);
    }
    .nav-dropdown a + a { margin-top: 0.55rem; }
    .nav-dropdown a:hover {
      color: var(--c-primary);
      border-color: rgba(155,240,255,0.16);
      background: rgba(155,240,255,0.05);
    }
    .dropdown-label {
      display: block;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--c-accent);
      margin-bottom: 0.2rem;
    }
    .dropdown-desc {
      display: block;
      font-size: 0.78rem;
      color: var(--c-muted);
      letter-spacing: normal;
      text-transform: none;
    }
    .btn-contact {
      background: var(--c-primary);
      color: #000000;
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      font-size: 0.7rem; font-weight: 800;
      letter-spacing: 0.15em; text-transform: uppercase;
      border: none; cursor: pointer; text-decoration: none;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-contact:hover { opacity: 0.88; transform: scale(1.04); }
    .nav-links a.btn-contact,
    .nav-links a.btn-contact:hover,
    .nav-links a.btn-contact:active,
    .nav-links a.btn-contact:visited {
      color: #000000;
    }

    .lang-toggle {
      display: flex; align-items: center; gap: 0.25rem;
      background: rgba(155,240,255,0.08);
      border: 1px solid var(--c-border);
      border-radius: 9999px; padding: 0.25rem 0.5rem;
      cursor: pointer;
    }
    .lang-toggle button {
      background: none; border: none; cursor: pointer;
      font-size: 0.65rem; font-weight: 800;
      letter-spacing: 0.15em; padding: 0.25rem 0.5rem;
      border-radius: 9999px; transition: all 0.2s;
      color: var(--c-muted);
    }
    .lang-toggle button.active {
      background: var(--c-primary);
      color: #001f24;
    }

    .md-only-lang { display: none; }

    main { max-width: 1280px; margin: auto; padding: 6rem 1.5rem 4rem; }

    .hero {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; gap: 2rem; padding: 4rem 0;
    }
    .hero > .avatar-ring {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
      animation: heroRise 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
    }
    .hero h1,
    .hero .hero-sub,
    .hero .hero-cta {
      opacity: 0;
      transform: translateY(20px);
      animation: heroRise 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .hero h1 { animation-delay: 0.2s; }
    .hero .hero-sub { animation-delay: 0.32s; }
    .hero .hero-cta { animation-delay: 0.45s; }

    .avatar-ring {
      position: relative; width: 200px; height: 200px;
      border-radius: 50%; overflow: hidden;
      box-shadow: 0 0 60px -10px rgba(112,213,230,0.35);
      border: 2px solid rgba(155,240,255,0.15);
    }
    .avatar-ring::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      pointer-events: none;
      box-shadow: 0 0 0 1px rgba(155,240,255,0.2);
    }
    .avatar-ring img { width: 100%; height: 100%; object-fit: cover; }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900; line-height: 1.15;
      letter-spacing: -0.02em;
    }
    .hero-title-line {
      display: inline-block;
      position: relative;
      padding-bottom: 0.08em;
    }
    .hero-title-line::after {
      content: '';
      position: absolute;
      inset-inline-start: 0;
      bottom: -0.12em;
      width: 100%;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, rgba(155,240,255,0.95), rgba(77,217,255,0.95), transparent);
      transform: scaleX(0);
      transform-origin: center;
      animation: titleLine 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
      opacity: 0.95;
    }
    body.lang-en .hero h1 { font-family: var(--font-en); }
    .gradient-text {
      position: relative;
      display: inline-block;
      background: linear-gradient(90deg, var(--c-primary), #4dd9ff);
      background-size: 100% 100%;
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
