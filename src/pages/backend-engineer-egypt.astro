    .hero,.card,.faq,.cta,.compare,.links-box,.journey,.note-box{background:var(--card);border:1px solid var(--bd);border-radius:16px}
    .hero{padding:1.5rem;margin:1rem 0}.hero h1{margin:.2rem 0 0;font-size:clamp(1.4rem,4vw,2.2rem)}
