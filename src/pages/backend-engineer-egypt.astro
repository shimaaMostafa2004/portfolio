    .card,.compare,.journey,.note-box{padding:1rem}.tag{font-size:.72rem;color:var(--acc);font-weight:700;letter-spacing:.08em}
    .faq,.cta,.links-box{padding:1.2rem;margin-top:1rem}.links a{color:var(--pri);text-decoration:none}
